        </button>
      `).join("");
    }

    function renderPrompts() {
      const query = normalize(state.query);
      let visibleCount = 0;

      const cards = prompts.map((prompt) => {
        const matchCategory = state.category === "All" || prompt.category === state.category;
        const matchQuery = !query || searchableText(prompt).includes(query);
        const hidden = !(matchCategory && matchQuery);
        if (!hidden) visibleCount += 1;

        return `
          <article class="card prompt-card searchable ${hidden ? "is-hidden" : ""}" id="prompt-${prompt.id}" data-category="${prompt.category}" data-search="${escapeHtml(searchableText(prompt))}">
            <div class="prompt-top">
              <span class="pill">${prompt.category}</span>
              <button class="btn compact" type="button" data-copy="${prompt.id}">複製</button>
            </div>
            <h3>${prompt.title}</h3>
            <p>${prompt.scenario}</p>
            <div class="prompt-box">${escapeHtml(prompt.content)}</div>
          </article>
        `;
      }).join("");

      promptGrid.innerHTML = cards + promptEmpty.outerHTML;
      promptGrid.querySelector("#promptEmpty").style.display = visibleCount ? "none" : "block";
      resultLine.textContent = state.query || state.category !== "All" ? `找到 ${visibleCount} 個 Prompt` : "";
