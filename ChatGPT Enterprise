      toast.classList.add("show");
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => toast.classList.remove("show"), 1800);
    }

    async function copyPrompt(id) {
      const prompt = prompts.find((item) => item.id === id);
      if (!prompt) return;
      try {
        await navigator.clipboard.writeText(prompt.content);
      } catch {
        const textarea = document.createElement("textarea");
        textarea.value = prompt.content;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
      }
      showToast(`已複製「${prompt.title}」`);
    }

    function openCourse(id) {
      const course = courses.find((item) => item.id === id);
      if (!course) return;
      modalPill.textContent = course.lesson;
      modalTitle.textContent = course.title;
      modalBody.innerHTML = `
        <p>${course.detail}</p>
        <ul>${course.highlights.map((item) => `<li>${item}</li>`).join("")}</ul>
        <button class="btn primary" type="button" data-modal-scroll="#prompts">前往 Prompt Library</button>
      `;
      modalBackdrop.classList.add("show");
    }

    function openGuide(index) {
      const guide = guides[index];
      if (!guide) return;
      modalPill.textContent = "Quick Guide";
      modalTitle.textContent = guide.title;
      modalBody.innerHTML = `
        <p>${guide.description}</p>
        <ul>${guide.items.map((item) => `<li>${item}</li>`).join("")}</ul>
      `;
      modalBackdrop.classList.add("show");
    }

    function closeModal() {
      modalBackdrop.classList.remove("show");
    }

    function jumpToPrompt(id) {
      state.category = "All";
      state.query = "";
      document.querySelector("#siteSearch").value = "";
      renderFilters();
      applyGlobalSearch();
      const target = document.querySelector(`#prompt-${id}`);
      if (!target) return;
      target.scrollIntoView({ behavior: "smooth", block: "center" });
      target.classList.remove("flash");
      requestAnimationFrame(() => target.classList.add("flash"));
    }

    function applyGlobalSearch() {
      const query = normalize(state.query);
      document.querySelectorAll(".searchable").forEach((element) => {
        if (element.classList.contains("prompt-card")) return;
        const match = !query || element.dataset.search.includes(query);
        element.classList.toggle("is-hidden", !match);
      });
      renderPrompts();
    }

    function updateActiveNav() {
      const sections = ["home", "courses", "prompts", "workflow", "guide", "faq"]
        .map((id) => document.getElementById(id))
        .filter(Boolean);
      const current = sections.reduce((active, section) => {
        const rect = section.getBoundingClientRect();
        return rect.top <= 140 ? section.id : active;
      }, "home");

      document.querySelectorAll(".nav a").forEach((link) => {
        link.classList.toggle("active", link.getAttribute("href") === `#${current}`);
      });
    }

    renderCourses();
    renderFilters();
    renderPrompts();
    renderQuickLinks();
    renderWorkflows();
    renderGuides();
    renderFaqs();

    document.addEventListener("click", (event) => {
      const copyButton = event.target.closest("[data-copy]");
      if (copyButton) copyPrompt(copyButton.dataset.copy);

      const filterButton = event.target.closest("[data-filter]");
      if (filterButton) {
        state.query = document.querySelector("#siteSearch").value;
        state.category = filterButton.dataset.filter;
        renderFilters();
        applyGlobalSearch();
      }

      const courseButton = event.target.closest("[data-course]");
      if (courseButton) openCourse(courseButton.dataset.course);

      const guideButton = event.target.closest("[data-guide]");
      if (guideButton) openGuide(Number(guideButton.dataset.guide));

      const promptJump = event.target.closest("[data-jump-prompt]");
      if (promptJump) jumpToPrompt(promptJump.dataset.jumpPrompt);

      const modalScroll = event.target.closest("[data-modal-scroll]");
      if (modalScroll) {
        closeModal();
        document.querySelector(modalScroll.dataset.modalScroll)?.scrollIntoView({ behavior: "smooth" });
      }

      if (event.target === modalBackdrop || event.target.closest("#modalClose")) closeModal();

      if (event.target.closest(".nav a")) sidebar.classList.remove("open");

      const step = event.target.closest(".step");
      if (step) step.classList.toggle("active");
    });

    document.querySelector("#siteSearch").addEventListener("input", (event) => {
      state.query = event.target.value;
      applyGlobalSearch();
    });

    document.querySelector("#menuButton").addEventListener("click", () => {
      sidebar.classList.toggle("open");
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeModal();
        sidebar.classList.remove("open");
      }
    });

    window.addEventListener("scroll", updateActiveNav, { passive: true });
    updateActiveNav();
  </script>
</body>
</html>
